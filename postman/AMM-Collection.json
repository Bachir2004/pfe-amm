            "url": { "raw": "{{baseUrl}}/api/dossiers/health", "host": ["{{baseUrl}}"], "path": ["api","dossiers","health"] }
          }
        },

        {
          "name": "23 — Actuator Health (Spring Boot)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Statut UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [],
